generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// УДАЛИЛИ блоки enum Role, JobStatus и т.д.

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   // Поменяли Role на String
  createdAt    DateTime @default(now())

  jobs         Job[]    @relation("UserJobs")
  applications Application[] @relation("UserApplications")
}

model Job {
  id          String    @id @default(uuid())
  ownerId     String
  owner       User      @relation("UserJobs", fields: [ownerId], references: [id])

  title       String
  companyName String
  location    String?
  level       String    @default("Junior")
  salaryFrom  Int?
  salaryTo    Int?
  description String
  tags        String    @default("") // Поменяли String[] на String
  status      String    @default("published") // Поменяли JobStatus на String

  createdAt   DateTime  @default(now())
  applications Application[]
}

model Application {
  id          String            @id @default(uuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id])

  candidateId String
  candidate   User              @relation("UserApplications", fields: [candidateId], references: [id])

  coverLetter String?
  status      String            @default("new") // Поменяли ApplicationStatus на String
  createdAt   DateTime          @default(now())

  messages    Message[]
  @@unique([jobId, candidateId])
}

model Message {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  senderId      String
  text          String
  createdAt     DateTime    @default(now())
}